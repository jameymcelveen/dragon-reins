{
  "name": "dragon-reins",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build:driver": "xcodebuild -project apps/native-manager/DragonReins.xcodeproj -scheme DragonReinsDriver",
    "build:manager": "xcodebuild -project apps/native-manager/DragonReins.xcodeproj -scheme DragonReins",
    "copy:bin": "cp -R apps/native-manager/build/Release/DragonReins.app ./bin/",
    "dev:ui": "cd apps/electron-ui && npm run start",
    "deploy:all": "npm run build:driver && npm run build:manager && npm run copy:bin"
  },
  "keywords": ["keyboard", "dragon", "reins", "led", "rgb"],
  "author": "Jamey McElveen",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1"
}
